<?xml version="1.0" encoding="utf-8"?>

<features:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:DataType="features:NewTimeslotPageViewModel"
             xmlns:features="clr-namespace:FastingFriend.Features"
             x:Class="FastingFriend.Features.NewTimeslotPage">
    <Grid>
        <ContentView BackgroundColor="#00000005"/>
        <Border BackgroundColor="White" StrokeShape="RoundRectangle 16 16 0 0">
            <Grid ColumnDefinitions="*, 2*"
                  RowDefinitions="*, *, *">
                <Label Grid.Row="0" Grid.Column="0" Text="Start Time"/>
                <TimePicker Grid.Row="0" Grid.Column="1" Time="{Binding StartDateTime}"/>
                
                <Label
                    Grid.Row="1" Grid.Column="0"
                    Text="End Time"/>
                <TimePicker Grid.Row="1" Grid.Column="1" Time="{Binding EndDateTime}"/>
                
                <Button
                    Text="Cancel" Grid.Row="2" Grid.Column="0" Command="{Binding CancelCommand}"/>
                <Button Text="Confirm" Grid.Row="2" Grid.Column="1" Command="{Binding ConfirmCommand}"/>
            </Grid>
        </Border>
    </Grid>
        
</features:BasePage>